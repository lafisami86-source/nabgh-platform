# ─── REQUIRED for Production ──────────────────────────────────────────

# MongoDB Atlas connection string
# Create a free cluster at https://www.mongodb.com/atlas
# Whitelist Vercel IPs (or allow 0.0.0.0/0 for serverless)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/nabgh?retryWrites=true&w=majority

# NextAuth — generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-production-secret-minimum-32-characters-long

# Set this to your Vercel deployment URL
NEXTAUTH_URL=https://your-app-name.vercel.app

# ─── Recommended for Production ───────────────────────────────────────

# Your public app URL (used by client-side code)
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app
NEXT_PUBLIC_APP_NAME=نبغ

# ─── Optional Features ────────────────────────────────────────────────

# OpenAI (for AI tutor / نبوغ)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Google OAuth (for social login)
# Set up at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudinary (for image/video uploads)
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
